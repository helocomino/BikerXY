@{
    ViewData["Title"] = "Bienvenido a BIKERXY";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 75vh;">
    <div class="text-center p-5 shadow-lg rounded bg-white border border-light" style="max-width: 500px; width: 100%;">
        <div class="mb-4">
            <h1 class="display-3 fw-bold tracking-tight text-dark" style="letter-spacing: 2px;">BIKERXY</h1>
            <p class="text-muted uppercase small fw-semibold">Premium Motorcycle Store</p>
        </div>

        <h3 class="h5 mb-4 text-secondary">Selecciona cómo deseas ingresar al catálogo</h3>

        <div class="d-grid gap-3">
            <a asp-controller="Motos" asp-action="Index" class="btn btn-dark btn-lg py-3 shadow-sm fw-bold">
                🏍️ Entrar como Invitado
            </a>

            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-dark btn-lg py-3 fw-bold">
                👤 Iniciar Sesión
            </a>
        </div>

        <div class="mt-4 pt-3 border-top">
            <p class="mb-0 text-muted small">
                ¿Aún no tienes una cuenta?
                <a asp-controller="Account" asp-action="Register" class="text-dark fw-bold text-decoration-none border-bottom border-dark">Regístrate aquí</a>
            </p>
        </div>
    </div>
</div>