@{
    ViewData["Title"] = "Bienvenido a BIKERXY";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 80vh;">

    <div class="text-center p-5 shadow-lg rounded text-white border border-secondary"
         style="max-width: 500px; width: 100%; background-color: rgba(20, 20, 20, 0.85) !important; backdrop-filter: blur(10px);">

        <div class="mb-4">
            <h1 class="display-3 fw-bold tracking-tight" style="letter-spacing: 2px;">BIKER<span class="text-gold">XY</span></h1>
            <p class="text-muted uppercase small fw-semibold" style="letter-spacing: 3px; color: #dfba6b !important;">Premium Motorcycle Store</p>
        </div>

        <h3 class="h6 mb-4 text-light opacity-75">Selecciona cómo deseas ingresar al catálogo</h3>

        <div class="d-grid gap-3">
            <a class="btn btn-outline-light btn-lg py-3 fw-bold" asp-controller="Motos" asp-action="Index" style="transition: all 0.3s ease;">
                🏍️ Entrar como Invitado
            </a>

            <a class="btn btn-gold-action btn-lg py-3 fw-bold text-dark" asp-controller="Account" asp-action="Login" style="background-color: #dfba6b; border-color: #dfba6b; transition: all 0.3s ease;">
                👤 Iniciar Sesión
            </a>
        </div>

        <div class="mt-4 pt-3 border-top border-secondary">
            <p class="mb-0 text-muted small">
                ¿Aún no tienes una cuenta?
                <a asp-controller="Account" asp-action="Register" class="fw-bold text-decoration-none" style="color: #dfba6b;">Regístrate aquí</a>
            </p>
        </div>
    </div>
</div>