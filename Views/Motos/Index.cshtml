@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model IEnumerable<BikerXY.Models.Moto>

@{
    ViewData["Title"] = "Catálogo de Motos";
}

<div class="container mt-5">
    <div class="mb-4 text-center">
        <h1 class="display-4 fw-bold text-white" style="letter-spacing: 1px;">Catálogo de Motos BIKER<span style="color: #dfba6b;">XY</span></h1>
        <p class="text-muted">Encuentra la moto ideal para tu estilo urbano o deportivo.</p>
    </div>

    <!-- 🔍 BUSCADOR MODERNO CON MICRÓFONO INTEGRADO -->
    <div class="container mb-5" style="max-width: 650px;">
        <form asp-action="Index" method="get" id="searchForm">
            <div class="input-group shadow-lg" style="border: 1px solid #dfba6b; border-radius: 50px; overflow: hidden; background-color: #212529;">
                <!-- Icono de lupa -->
                <span class="input-group-text bg-transparent border-0 text-muted ps-3">🔍</span>
                
                <!-- Input de búsqueda de texto -->
                <input type="text" name="buscar" id="searchInput" class="form-control bg-transparent border-0 text-white py-2" placeholder="Busca por marca, modelo o categoría..." value="@Context.Request.Query["buscar"]" autocomplete="off" style="box-shadow: none;" />
                
                <!-- BOTÓN DEL MICRÓFONO -->
                <button type="button" id="micButton" class="btn bg-transparent border-0 text-warning px-3" title="Buscar por voz" style="box-shadow: none; z-index: 10;">
                    <span id="micIcon" style="font-size: 1.2rem;">🎙️</span>
                </button>
                
                <!-- Botón Buscar clásico -->
                <button type="submit" class="btn fw-bold px-4 m-1 rounded-pill shadow-sm" style="background-color: #dfba6b; color: #141414;">Buscar</button>
            </div>
            <!-- Indicador visual de escucha -->
            <div id="micStatus" class="text-center mt-2" style="display: none; color: #dfba6b !important; font-weight: bold;">
                <span class="spinner-grow spinner-grow-sm text-danger me-1" role="status"></span>
                🔴 Escuchando... habla ahora: <span id="liveTranscript" class="text-white-50 italic"></span>
            </div>
        </form>
    </div>

    <!-- Lista de Motos -->
    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center my-5">
                <h3 class="text-muted">No se encontraron motos que coincidan con tu búsqueda.</h3>
                <a asp-action="Index" class="btn btn-outline-warning mt-3 rounded-pill">Ver todo el catálogo</a>
            </div>
        }
        else
        {
            @foreach (var moto in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 bg-dark text-white" style="border: 1px solid #333 !important;">
                        <img src="@moto.ImagenUrl" class="card-img-top" alt="@moto.Modelo" style="height: 220px; object-fit: cover;">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title font-weight-bold text-warning">@moto.Marca @moto.Modelo</h5>
                            <p class="card-text text-secondary mb-1"><strong>Año:</strong> @moto.Anio</p>
                            <p class="card-text text-secondary mb-1"><strong>Cilindrada:</strong> @moto.Cilindrada cc</p>
                            <p class="card-text text-secondary mb-1"><strong>Estado:</strong> <span class="badge bg-secondary">@moto.Estado</span></p>
                            <p class="card-text text-secondary"><strong>Categoría:</strong> @moto.Categoria</p>
                            <div class="mt-auto">
                                <h4 class="font-weight-bold mb-3" style="color: #dfba6b;">$@moto.Precio.ToString("N2")</h4>
                                @if (moto.Stock > 0)
                                {
                                    <button class="btn btn-light w-100 btn-agregar-carrito fw-bold text-dark"
                                            data-id="@moto.Id"
                                            data-stock="@moto.Stock"
                                            data-logeado="@(HttpContextAccessor.HttpContext?.Session.GetString("UsuarioNombre") != null ? "true" : "false")">
                                        Agregar al carrito
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-danger w-100" disabled>❌ Agotado</button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- 🧠 JS MEJORADO CON ESCRITURA EN TIEMPO REAL -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const micButton = document.getElementById("micButton");
        const micIcon = document.getElementById("micIcon");
        const searchInput = document.getElementById("searchInput");
        const searchForm = document.getElementById("searchForm");
        const micStatus = document.getElementById("micStatus");
        const liveTranscript = document.getElementById("liveTranscript");

        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

        if (!SpeechRecognition) {
            alert("Tu navegador no soporta búsqueda por voz. Prueba usando Google Chrome o Microsoft Edge.");
            micButton.style.display = "none";
            return;
        }

        const recognition = new SpeechRecognition();
        recognition.lang = 'es-ES';
        recognition.interimResults = true; // ACTIVADO: Permite escribir en la pantalla mientras estás hablando
        recognition.continuous = false;

        let isListening = false;

        micButton.addEventListener("click", function (e) {
            e.preventDefault();
            if (!isListening) {
                try {
                    recognition.start();
                } catch (err) {
                    console.error(err);
                }
            } else {
                recognition.stop();
            }
        });

        recognition.onstart = function () {
            isListening = true;
            micIcon.innerText = "🛑";
            micStatus.style.display = "block";
            liveTranscript.innerText = "...";
            searchInput.value = "";
            searchInput.placeholder = "Escuchando...";
        };

        // MIENTRAS ESTÁS HABLANDO, VA ESCRIBIENDO EN EL INPUT
        recognition.onresult = function (event) {
            let interimTranscript = '';
            let finalTranscript = '';

            for (let i = event.resultIndex; i < event.results.length; ++i) {
                if (event.results[i].isFinal) {
                    finalTranscript += event.results[i][0].transcript;
                } else {
                    interimTranscript += event.results[i][0].transcript;
                }
            }

            // Muestra en vivo lo que entiende el navegador
            const textoActual = finalTranscript || interimTranscript;
            searchInput.value = textoActual;
            liveTranscript.innerText = `"${textoActual}"`;
        };

        recognition.onerror = function (event) {
            console.error("Error de voz: ", event.error);
            if(event.error === 'not-allowed') {
                alert("Permiso de micrófono denegado. Por favor, activa el micrófono en el candado de la barra de direcciones de tu navegador.");
            }
            resetMicUI();
        };

        recognition.onend = function () {
            resetMicUI();
            // Si el usuario logró decir algo, enviamos el buscador automáticamente al terminar
            if (searchInput.value.trim() !== "") {
                setTimeout(() => { searchForm.submit(); }, 800);
            }
        };

        function resetMicUI() {
            isListening = false;
            micIcon.innerText = "🎙️";
            micStatus.style.display = "none";
            searchInput.placeholder = "Busca por marca, modelo o categoría...";
        }
    });
</script>