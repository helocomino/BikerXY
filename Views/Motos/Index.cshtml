@model IEnumerable<BikerXY.Models.Moto>

@{
    ViewData["Title"] = "Catálogo de Motos";
}

<div class="container mt-5">
    <h1 class="text-center mb-4 font-weight-bold">Catálogo de Motos BikerXY</h1>
    <p class="text-muted text-center mb-5">Encuentra la moto ideal para tu estilo urbano o deportivo.</p>

    <div class="row">
        @foreach (var moto in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="@moto.ImagenUrl" class="card-img-top" alt="@moto.Modelo" style="height: 220px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title font-weight-bold">@moto.Marca @moto.Modelo</h5>
                        <p class="card-text text-secondary mb-1"><strong>Cilindrada:</strong> @moto.Cilindrada cc</p>
                        <p class="card-text text-secondary"><strong>Categoría:</strong> @moto.Categoria</p>
                        <div class="mt-auto">
                            <h4 class="text-success font-weight-bold mb-3">$@moto.Precio.ToString("N2")</h4>
                            <button class="btn btn-dark w-100 font-weight-bold">Agregar al Carrito</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>