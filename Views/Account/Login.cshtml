@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="text-center mb-4 font-weight-bold">Iniciar Sesión</h2>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger p-2 small text-center" role="alert">
                        @ViewBag.Error
                    </div>
                }

                <form asp-action="Login" method="post">
                    <div class="form-group mb-3">
                        <label class="form-label">Correo Electrónico</label>
                        <input name="correo" type="email" class="form-control" placeholder="ejemplo@correo.com" required />
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label">Contraseña</label>
                        <input name="contrasena" type="password" class="form-control" placeholder="Tu contraseña" required />
                    </div>

                    <button type="submit" class="btn btn-dark w-100 btn-lg mb-3">Ingresar</button>
                </form>

                <div class="text-center mt-3">
                    <span class="text-muted">¿No tienes una cuenta?</span>
                    <a asp-action="Register" class="text-dark font-weight-bold ml-1">Regístrate aquí</a>
                </div>
            </div>
        </div>
    </div>
</div>