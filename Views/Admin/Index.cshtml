@model IEnumerable<BikerXY.Models.Moto>

@{
    ViewData["Title"] = "Panel de Control - BIKERXY";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🛠️ Panel de Administración de Inventario</h2>
        <a asp-action="Create" class="btn btn-success fw-bold">+ Añadir Nueva Moto</a>
    </div>

    <div class="card shadow-sm p-3">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Imagen</th>
                    <th>Marca / Modelo</th>
                    <th>Cilindrada</th>
                    <th>Ambiente</th>
                    <th>Precio</th>
                    <th class="text-center">Stock Real</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="@item.ImagenUrl" alt="Moto" style="width: 60px; height: auto;" class="rounded bg-light" />
                        </td>
                        <td>
                            <strong>@item.Marca</strong> <span class="text-muted">@item.Modelo</span>
                        </td>
                        <td>@item.Cilindrada cc</td>
                        <td><span class="badge bg-secondary">@item.Ambiente</span></td>
                        <td class="fw-bold text-success">@item.Precio.ToString("C")</td>
                        <td class="text-center">
                            @if (item.Stock == 0)
                            {
                                <span class="badge bg-danger p-2">⚠️ Agotado (0)</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark p-2 fw-bold">📦 @item.Stock Unidades</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-2">✏️ Editar</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Seguro que deseas eliminar esta moto por completo?');">🗑️ Borrar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>