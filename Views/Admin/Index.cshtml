@model IEnumerable<BikerXY.Models.Moto>

@{
    ViewData["Title"] = "Panel de Administración - BikerXY";
}

<div class="container mt-5 pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white fw-bold border-bottom border-warning pb-2">🛠️ Panel de Control de Inventario</h2>
        <a asp-action="Create" class="btn btn-warning fw-bold shadow">➕ Añadir Nueva Moto</a>
    </div>

    <div class="table-responsive bg-dark p-3 rounded shadow" style="border: 1px solid #dfba6b;">
        <table class="table table-dark table-hover align-middle m-0">
            <thead class="table-light text-dark fw-bold text-uppercase" style="background-color: #dfba6b !important; border-color: #dfba6b;">
                <tr>
                    <th>Imagen</th>
                    <th>Marca</th>
                    <th>Modelo</th>
                    <th>Año</th>
                    <th>Cilindrada</th>
                    <th>Precio</th>
                    <th>Estado</th>
                    <th>Stock</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImagenUrl))
                            {
                                <img src="@item.ImagenUrl" alt="@item.Modelo" class="rounded" style="width: 80px; height: 50px; object-fit: cover; border: 1px solid #555;" />
                            }
                            else
                            {
                                <span class="badge bg-secondary">Sin Foto</span>
                            }
                        </td>
                        <td class="fw-bold text-white">@item.Marca</td>
                        <td>@item.Modelo</td>
                        <td>@item.Anio</td>
                        <td><span class="badge bg-info text-dark">@item.Cilindrada cc</span></td>
                        <td class="text-warning fw-bold">$@item.Precio.ToString("N2")</td>
                        <td>
                            @if (item.Estado == "Nueva")
                            {
                                <span class="badge bg-success">Nueva</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Usada</span>
                            }
                        </td>
                        <td>
                            @if (item.Stock > 0)
                            {
                                <span class="badge bg-outline-light">@item.Stock u.</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Agotado</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">✏️ Editar</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Seguro que deseas eliminar esta moto?');">🗑️ Borrar</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>