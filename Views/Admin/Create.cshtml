@model BikerXY.Models.Moto

@{
    ViewData["Title"] = "Añadir Moto";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow p-4 border-0">
        <h3 class="text-success mb-4">+ Añadir Nueva Moto al Catálogo</h3>
        <hr />
        <form asp-action="Create" method="post">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Marca" class="form-label fw-bold">Marca</label>
                    <input asp-for="Marca" class="form-control" placeholder="Ej: Yamaha" required />
                </div>
                <div class="col-md-6">
                    <label asp-for="Modelo" class="form-label fw-bold">Modelo</label>
                    <input asp-for="Modelo" class="form-control" placeholder="Ej: R6" required />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Cilindrada" class="form-label fw-bold">Cilindrada (cc)</label>
                    <input asp-for="Cilindrada" type="number" class="form-control" placeholder="Ej: 600" required />
                </div>
                <div class="col-md-6">
                    <label asp-for="Precio" class="form-label fw-bold">Precio ($)</label>
                    <input asp-for="Precio" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Stock" class="form-label fw-bold">📦 Stock Inicial</label>
                    <input asp-for="Stock" type="number" class="form-control" value="1" required />
                </div>
                <div class="col-md-6">
                    <label asp-for="Ambiente" class="form-label fw-bold">⛰️ Ambiente / Tipo</label>
                    <select asp-for="Ambiente" class="form-select" required>
                        <option value="Pistera">Pistera</option>
                        <option value="Terreno">Terreno</option>
                        <option value="Carretera">Carretera</option>
                    </select>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="ImagenUrl" class="form-label fw-bold">Enlace de la Imagen (URL)</label>
                <input asp-for="ImagenUrl" class="form-control" placeholder="https://..." required />
            </div>

            <div class="mb-4">
                <label asp-for="Descripcion" class="form-label fw-bold">Ficha Técnica / Descripción</label>
                <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Detalles de motor, frenos, etc..."></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success btn-lg w-100">Publicar Moto</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg w-100">Volver</a>
            </div>
        </form>
    </div>
</div>