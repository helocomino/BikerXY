@model BikerXY.Models.Moto

@{
    ViewData["Title"] = "Añadir Moto - BikerXY";
}

<div class="container mt-5 pt-4" style="max-width: 600px;">
    <div class="card bg-dark text-white shadow p-4" style="border: 1px solid #dfba6b;">
        <h2 class="text-center fw-bold text-warning mb-4">➕ Añadir Nueva Moto</h2>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Marca" class="form-label fw-bold">Marca</label>
                    <input asp-for="Marca" class="form-value form-control bg-secondary text-white border-0" placeholder="Ej: Yamaha" required />
                    <span asp-validation-for="Marca" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Modelo" class="form-label fw-bold">Modelo</label>
                    <input asp-for="Modelo" class="form-control bg-secondary text-white border-0" placeholder="Ej: R1" required />
                    <span asp-validation-for="Modelo" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Anio" class="form-label fw-bold">Año</label>
                    <input asp-for="Anio" type="number" class="form-control bg-secondary text-white border-0" placeholder="Ej: 2024" required />
                    <span asp-validation-for="Anio" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Cilindrada" class="form-label fw-bold">Cilindrada (cc)</label>
                    <input asp-for="Cilindrada" type="number" class="form-control bg-secondary text-white border-0" placeholder="Ej: 998" required />
                    <span asp-validation-for="Cilindrada" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Precio" class="form-label fw-bold">Precio ($)</label>
                    <input asp-for="Precio" type="number" step="0.01" class="form-control bg-secondary text-white border-0" placeholder="Ej: 17500.00" required />
                    <span asp-validation-for="Precio" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Stock" class="form-label fw-bold">Stock Disponible</label>
                    <input asp-for="Stock" type="number" class="form-control bg-secondary text-white border-0" value="1" required />
                    <span asp-validation-for="Stock" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Estado" class="form-label fw-bold">Estado del Vehículo</label>
                    <select asp-for="Estado" class="form-select bg-secondary text-white border-0">
                        <option value="Nueva">Nueva</option>
                        <option value="Usada">Usada</option>
                    </select>
                    <span asp-validation-for="Estado" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Categoria" class="form-label fw-bold">Categoría</label>
                    <input asp-for="Categoria" class="form-control bg-secondary text-white border-0" placeholder="Ej: Deportiva, Naked" />
                    <span asp-validation-for="Categoria" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="ImagenUrl" class="form-label fw-bold">URL de la Imagen</label>
                <input asp-for="ImagenUrl" class="form-control bg-secondary text-white border-0" placeholder="https://enlace-de-la-foto.com/imagen.jpg" />
                <span asp-validation-for="ImagenUrl" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Descripcion" class="form-label fw-bold">Descripción</label>
                <textarea asp-for="Descripcion" rows="3" class="form-control bg-secondary text-white border-0" placeholder="Detalles de la motocicleta..."></textarea>
                <span asp-validation-for="Descripcion" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning fw-bold w-100 shadow">💾 Guardar Moto</button>
                <a asp-action="Index" class="btn btn-outline-light w-100">❌ Cancelar</a>
            </div>
        </form>
    </div>
</div>